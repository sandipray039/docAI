# --- Required ---
# Get a FREE Groq API key at: https://console.groq.com (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here

# --- Optional (these defaults work fine) ---
LLM_MODEL=llama3-8b-8192       # other free options: llama3-70b-8192, mixtral-8x7b-32768
EMBEDDING_MODEL=all-MiniLM-L6-v2  # runs on CPU, no API key
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=5
CORS_ORIGINS=*
